// schema.prisma — PayPol Protocol (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 🏢 WORKSPACE & PAYROLL (Phase 1)
// ==========================================

// Multi-tenant Workspace
model Workspace {
  id              String   @id @default(uuid())
  name            String   @unique
  adminWallet     String   @unique
  type            String?
  daemonStatus    String   @default("OFFLINE")
  daemonLastSeen  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  payloads        TimeVaultPayload[]
  employees       Employee[]
}

// Shielded Transaction Ledger
model TimeVaultPayload {
  id              String   @id @default(uuid())
  workspaceId     String
  name            String?
  token           String   @default("AlphaUSD")
  note            String?
  isDiscovery     Boolean  @default(false)
  recipientWallet String
  isShielded      Boolean  @default(false)
  zkCommitment    String?
  zkProof         String?
  amount          Float?
  status          String   @default("Draft")
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id])

  @@index([status])
  @@index([status, isShielded])
  @@index([workspaceId])
  @@index([recipientWallet])
  @@index([workspaceId, status, createdAt])
}

// Employee Payroll (replaces legacy sqlite employees table)
model Employee {
  id            String   @id @default(uuid())
  workspaceId   String?
  name          String   @default("Anonymous")
  walletAddress String
  amount        Float
  token         String   @default("AlphaUSD")
  note          String?
  status        String   @default("Awaiting_Approval") // Awaiting_Approval, Pending, Vaulted, Cancel_Requested, Paid
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([status])
  @@index([walletAddress])
  @@index([workspaceId, status])
}

// ZK Payroll Payout History
model PayoutRecord {
  id        String   @id @default(cuid())
  recipient String
  amount    Float
  token     String   @default("AlphaUSD")
  txHash    String   @unique
  createdAt DateTime @default(now())

  @@index([recipient])
  @@index([createdAt])
}

// 🤖 Autopilot Agent Rules (Recurring Payouts)
model AutopilotRule {
  id             Int      @id @default(autoincrement()) // Using Int as UI passes id: number
  name           String
  wallet_address String
  amount         Float
  token          String   @default("AlphaUSD")
  schedule       String   // e.g., "Daily", "Weekly", "Monthly (1st)"
  note           String?
  status         String   @default("Active") // Status: "Active" or "Paused"
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([wallet_address])
}

// 📝 Boardroom Queue (OmniTerminal Intents)
// Stores temporary transactions before Admin signs the Escrow
model EmployeeTx {
  id            String   @id @default(uuid())
  name          String
  walletAddress String
  amount        String
  token         String   @default("AlphaUSD")
  note          String?
  isDiscovery   Boolean  @default(false)
  status        String   @default("AWAITING") // Status: "AWAITING", "PENDING"
  createdAt     DateTime @default(now())
}

// ==========================================
// 🤖 AGENT MARKETPLACE
// ==========================================

// Agent profiles registered in the marketplace
model MarketplaceAgent {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String
  category      String   // security, defi, payroll, analytics, automation, compliance, governance, tax, nft, deployment
  skills        String   // JSON array: ["audit","solidity","reentrancy"]
  basePrice     Float
  webhookUrl    String?  // null = native PayPol agent
  nativeAgentId String?  // maps to /services/agents/:id (e.g. "contract-auditor")
  ownerWallet   String
  avatarEmoji   String   @default("🤖")
  avatarUrl     String?  // DiceBear or custom avatar image URL
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  totalJobs     Int      @default(0)
  successRate   Float    @default(100.0)
  avgRating     Float    @default(0)
  ratingCount   Int      @default(0)
  responseTime  Int      @default(30) // avg seconds
  source        String   @default("native")  // native | community | eliza | crewai | langchain | olas
  sourceUrl     String?                       // GitHub repo or framework docs URL
  githubHandle  String?                       // Contributor's GitHub username (for community agents)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  jobs          AgentJob[]
  reviews       AgentReview[]

  @@index([category])
  @@index([isActive])
  @@index([ownerWallet])
}

// Job lifecycle: CREATED → MATCHED → NEGOTIATING → ESCROW_LOCKED → EXECUTING → COMPLETED | FAILED | DISPUTED | SETTLED | REFUNDED
model AgentJob {
  id              String    @id @default(uuid())
  agentId         String
  agent           MarketplaceAgent @relation(fields: [agentId], references: [id])
  clientWallet    String
  prompt          String    // original user prompt
  taskDescription String?
  budget          Float
  negotiatedPrice Float?
  platformFee     Float?    // 8% of negotiated
  token           String    @default("AlphaUSD")
  status          String    @default("CREATED")
  result          String?   // JSON: agent output
  escrowTxHash    String?
  settleTxHash    String?
  onChainJobId    Int?      // Maps to PayPolNexusV2 contract's job ID
  disputeReason   String?   // Why employer disputed
  deadline        DateTime? // Auto-refund deadline (block.timestamp + deadlineDuration)
  executionTime   Int?      // seconds
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?
  reviews         AgentReview[]
  verdicts        JudgeVerdict[]

  // ── A2A (Agent-to-Agent) Fields ──
  parentJobId     String?   // Points to parent AgentJob.id for A2A chains
  parentAgentId   String?   // Which agent spawned this sub-task (e.g. "coordinator")
  a2aChainId      String?   // Groups all jobs in the same A2A chain
  depth           Int       @default(0) // Recursion depth in A2A chain
  stepIndex       Int?      // Position in orchestration plan (0-based)
  dependsOn       String?   // JSON array of step indices this step waits on: "[0, 1]"
  retryCount      Int       @default(0)  // Number of retry attempts (0 = first try)
  originalAgentId String?   // Original agent ID before fallback substitution

  // ── AI Proof Fields ──
  planHash        String?   // keccak256 of agent's planned approach
  resultHash      String?   // keccak256 of actual result
  commitmentId    String?   // On-chain AIProofRegistry commitment ID
  commitTxHash    String?   // TX hash of on-chain commitment
  verifyTxHash    String?   // TX hash of on-chain verification
  proofMatched    Boolean?  // Did planHash match resultHash?

  @@index([status])
  @@index([onChainJobId])
  @@index([deadline])
  @@index([clientWallet])
  @@index([clientWallet, status])
  @@index([agentId, status])
  @@index([a2aChainId])
  @@index([createdAt])
}

// Post-job reviews and ratings
model AgentReview {
  id        String   @id @default(uuid())
  jobId     String
  job       AgentJob @relation(fields: [jobId], references: [id])
  agentId   String
  agent     MarketplaceAgent @relation(fields: [agentId], references: [id])
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([jobId])
  @@unique([jobId])
}

// ==========================================
// 🔄 STREAM SETTLEMENT (Feature 7)
// ==========================================

// Progressive milestone-based escrow (PayPolStreamV1 contract)
model StreamJob {
  id              String       @id @default(uuid())
  agentJobId      String?      @unique          // Links to AgentJob if originated from marketplace
  clientWallet    String
  agentWallet     String
  agentName       String?
  totalBudget     Float
  releasedAmount  Float        @default(0)
  status          String       @default("ACTIVE")  // ACTIVE, COMPLETED, CANCELLED
  onChainStreamId Int?
  streamTxHash    String?
  deadline        DateTime?
  createdAt       DateTime     @default(now())
  milestones      Milestone[]

  swarmStream     SwarmStream?

  @@index([clientWallet])
  @@index([agentWallet])
}

// Individual milestone within a stream
model Milestone {
  id            String    @id @default(uuid())
  streamJobId   String
  streamJob     StreamJob @relation(fields: [streamJobId], references: [id])
  index         Int
  amount        Float
  deliverable   String
  proofHash     String?
  status        String    @default("PENDING")  // PENDING, SUBMITTED, APPROVED, REJECTED
  submitTxHash  String?
  approveTxHash String?
  rejectReason  String?
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@unique([streamJobId, index])
}

// ── Streaming Micropayments — Per-inference metering ──
model MeteringSession {
  id              String    @id @default(uuid())
  clientWallet    String
  agentWallet     String
  agentId         String?                // MarketplaceAgent ID
  token           String    @default("0x20c0000000000000000000000000000000000001")
  budgetCap       Float                  // Max spend allowed
  spent           Float     @default(0)  // Running total spent
  pricePerCall    Float     @default(0.1) // Price per inference/call
  totalCalls      Int       @default(0)  // Number of metered calls
  status          String    @default("ACTIVE") // ACTIVE, EXHAUSTED, CLOSED, SETTLED
  onChainStreamId Int?                   // Links to StreamV1 if on-chain
  settleTxHash    String?                // Final settlement transaction
  metadata        String?   @db.Text     // JSON: call log, usage details
  expiresAt       DateTime?              // Auto-close after this time
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientWallet])
  @@index([agentWallet])
  @@index([status])
}

// In-app notification system
model Notification {
  id          String   @id @default(uuid())
  wallet      String
  type        String   // stream:milestone_submitted, stream:milestone_approved, etc.
  title       String
  message     String
  streamJobId String?
  milestoneId String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([wallet, isRead])
  @@index([wallet, createdAt])
}

// ==========================================
// 💳 FIAT ON-RAMP (Paddle Integration)
// ==========================================

// Tracks credit card → crypto → escrow flow
model FiatPayment {
  id                   String    @id @default(uuid())
  paddleTransactionId  String    @unique
  paddlePaymentId      String?
  agentJobId           String?
  userWallet           String
  amountUSD            Float
  amountCrypto         Float?
  token                String    @default("AlphaUSD")
  shieldEnabled        Boolean   @default(false)
  status               String    @default("PENDING")  // PENDING, PAID, CRYPTO_SENT, SHIELD_DEPOSITED, ESCROWED, FAILED
  escrowTxHash         String?
  transferTxHash       String?
  shieldCommitment     String?
  shieldData           String?   // JSON: { secret, nullifier, nullifierHash, depositTxHash }
  createdAt            DateTime  @default(now())
  completedAt          DateTime?

  @@index([userWallet])
  @@index([paddleTransactionId])
}

// ==========================================
// 💸 FIAT OFF-RAMP (PayPal Payouts)
// ==========================================

// Tracks crypto → fiat withdrawal flow
model WithdrawalRequest {
  id                   String    @id @default(uuid())
  userWallet           String
  paypalEmail          String                                    // Recipient's PayPal email
  amountCrypto         Float                                     // AlphaUSD amount to withdraw
  amountUSD            Float                                     // USD amount after fees
  platformFee          Float                                     // PayPol fee (2.5%)
  paypalFee            Float     @default(0)                     // PayPal's fee
  token                String    @default("AlphaUSD")
  status               String    @default("PENDING")             // PENDING, CRYPTO_LOCKED, PROCESSING, COMPLETED, FAILED, CANCELLED
  lockTxHash           String?                                   // On-chain AlphaUSD lock/burn tx
  paypalPayoutId       String?   @unique                         // PayPal batch payout ID
  paypalPayoutItemId   String?                                   // PayPal individual payout item ID
  paypalTransactionId  String?                                   // PayPal transaction ID (after completion)
  failureReason        String?                                   // Why it failed
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  processedAt          DateTime?
  completedAt          DateTime?

  @@index([userWallet])
  @@index([status])
  @@index([paypalPayoutId])
  @@index([userWallet, status])
}

// ==========================================
// ⚡ CONDITIONAL PAYROLL
// ==========================================

// Rules that trigger payroll when conditions are met
model ConditionalRule {
  id              String    @id @default(uuid())
  name            String                          // Rule name/label
  recipients      String                          // JSON: [{ name, wallet, amount, token, note }]
  conditions      String                          // JSON: [{ type, param, operator, value }]
  conditionLogic  String    @default("AND")       // AND / OR
  status          String    @default("Watching")  // Watching, Paused, Triggered, Expired
  triggerCount    Int       @default(0)
  maxTriggers     Int       @default(1)           // How many times to trigger (-1 = infinite)
  cooldownMinutes Int       @default(0)           // Min minutes between triggers (0=one-time, 10080=weekly, 43200=monthly)
  note            String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  triggeredAt     DateTime?

  @@index([isActive])
}

// ==========================================
// 📈 ESCROW YIELD GENERATION (Feature 8)
// ==========================================

// Tracks yield accrued on locked escrow funds
model EscrowYield {
  id            String    @id @default(uuid())
  jobId         String                          // ref AgentJob id
  principal     Float                           // locked escrow amount
  token         String    @default("AlphaUSD")
  apy           Float     @default(5.0)         // 5% APY
  yieldEarned   Float     @default(0)
  status        String    @default("Accruing")  // Accruing | Settled | Withdrawn
  startedAt     DateTime  @default(now())
  settledAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([jobId])
  @@index([status])
}

// ==========================================
// 👛 EMBEDDED WALLETS (Feature 9)
// ==========================================

// Per-agent/employee wallet with encrypted private key
model EmbeddedWallet {
  id              String    @id @default(uuid())
  label           String                          // "Agent: ContractGuard" or "Employee: John"
  ownerType       String                          // "agent" | "employee"
  ownerId         String?                         // agentId or employee identifier
  address         String    @unique
  encryptedKey    String                          // AES-256-GCM encrypted private key
  iv              String                          // Initialization vector
  authTag         String                          // GCM auth tag
  balance         Float     @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?

  @@index([ownerType])
  @@index([address])
}

// ==========================================
// 🐝 AGENT SWARM FEATURES
// ==========================================

// Parent container for multi-agent swarms (Features 1+5)
model SwarmSession {
  id              String        @id @default(uuid())
  name            String                                  // "DeFi Audit Swarm"
  clientWallet    String
  totalBudget     Float                                   // Sum of all agent allocations
  totalReleased   Float         @default(0)
  agentCount      Int           @default(0)
  status          String        @default("ACTIVE")        // ACTIVE, COMPLETED, CANCELLED

  // Feature 5: Escrow fields
  escrowTxHash    String?                                 // NexusV2 escrow lock tx
  onChainJobId    Int?                                    // NexusV2 job ID
  totalLocked     Float         @default(0)               // Amount locked in escrow
  escrowStatus    String        @default("NONE")          // NONE, LOCKED, DISTRIBUTING, SETTLED

  deadline        DateTime?
  createdAt       DateTime      @default(now())
  completedAt     DateTime?

  streams         SwarmStream[]
  auditEvents     AuditEvent[]
  a2aTransfers    A2ATransfer[]

  @@index([clientWallet])
  @@index([status])
}

// Join table: SwarmSession <-> StreamJob (Feature 1)
model SwarmStream {
  id              String        @id @default(uuid())
  swarmId         String
  swarm           SwarmSession  @relation(fields: [swarmId], references: [id])
  streamJobId     String        @unique
  streamJob       StreamJob     @relation(fields: [streamJobId], references: [id])
  agentId         String?                                 // MarketplaceAgent id
  role            String        @default("worker")        // coordinator, worker, reviewer
  allocatedBudget Float
  releasedAmount  Float         @default(0)
  status          String        @default("ACTIVE")        // ACTIVE, COMPLETED, FAILED

  @@index([swarmId])
}

// Agent-to-agent micropayments (Feature 2)
model A2ATransfer {
  id                String        @id @default(uuid())
  senderAgentId     String?                               // MarketplaceAgent id
  receiverAgentId   String?                               // MarketplaceAgent id
  senderWallet      String
  receiverWallet    String
  amount            Float
  token             String        @default("AlphaUSD")
  reason            String?                               // "Subcontracted security scan"
  txHash            String?                               // On-chain tx hash
  swarmId           String?                               // Optional link to SwarmSession
  swarm             SwarmSession? @relation(fields: [swarmId], references: [id])
  jobId             String?                               // Optional link to AgentJob
  status            String        @default("PENDING")     // PENDING, CONFIRMED, FAILED
  createdAt         DateTime      @default(now())

  @@index([senderWallet])
  @@index([receiverWallet])
  @@index([swarmId])
  @@index([status])
}

// ZK-verified intelligence market (Feature 3)
model IntelSubmission {
  id                String        @id @default(uuid())
  sourceAgentId     String?                               // null = anonymous
  zkCommitment      String                                // Poseidon commitment hiding identity
  zkProof           String?                               // PLONK proof data
  nullifierHash     String?                               // Prevents double-submit

  category          String                                // security, defi, market, governance
  title             String
  summary           String                                // Brief description
  dataHash          String                                // keccak256 of full intel payload
  qualityScore      Float?                                // 0-100 post-verification
  price             Float                                 // AlphaUSD price
  token             String        @default("AlphaUSD")

  buyerWallet       String?                               // Who purchased
  paymentTxHash     String?                               // Payment tx
  proofRegistryId   String?                               // AIProofRegistry on-chain ID

  status            String        @default("LISTED")      // LISTED, VERIFIED, PURCHASED, EXPIRED
  createdAt         DateTime      @default(now())

  @@index([category])
  @@index([status])
  @@index([nullifierHash])
}

// ==========================================
// 🔑 API KEYS (Developer Authentication)
// ==========================================

// API keys for developer authentication
model ApiKey {
  id            String    @id @default(uuid())
  key           String    @unique                          // pp_live_xxxx or pp_test_xxxx
  name          String                                     // "My Production Key"
  ownerWallet   String                                     // Wallet that created this key
  permissions   String    @default("read,execute")         // CSV: read, execute, register, admin
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  rateLimit     Int       @default(100)                    // Requests per minute
  requestCount  Int       @default(0)                      // Total requests made
  createdAt     DateTime  @default(now())

  @@index([key])
  @@index([ownerWallet])
  @@index([isActive])
}

// ==========================================
// ⚖️ AUTO-JUDGE VERDICTS
// ==========================================

// Automated dispute resolution verdicts with confidence scoring
model JudgeVerdict {
  id              String    @id @default(uuid())
  jobId           String
  job             AgentJob  @relation(fields: [jobId], references: [id])
  verdict         String                                  // SETTLE, REFUND, ESCALATE
  confidence      Float                                   // 0.0 - 1.0
  reasoning       String                                  // JSON array of reasons
  layer           Int                                     // 1 = deterministic, 2 = AI scoring, 3 = human
  rulesFired      String?                                 // JSON array of rule IDs that triggered
  scores          String?                                 // JSON: { resultQuality, proofIntegrity, executionQuality, agentReputation, relevance }
  executedOnChain Boolean   @default(false)
  txHash          String?
  overriddenBy    String?                                 // wallet of human who overrode
  overrideVerdict String?                                 // original verdict before override
  executedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([jobId])
  @@index([verdict])
  @@index([createdAt])
  @@index([executedOnChain])
}

// ==========================================
// 💬 CHAT & MESSAGING
// ==========================================

// Chat channels (DM, group, agent-support)
model ChatChannel {
  id            String           @id @default(uuid())
  type          String           @default("dm")        // dm | group | agent | support
  name          String?                                // null for DMs, set for groups
  avatarUrl     String?                                // Group/channel avatar
  agentId       String?                                // Linked MarketplaceAgent (for agent channels)
  jobId         String?                                // Linked AgentJob (for job-specific chat)
  createdBy     String                                 // Wallet that created channel
  lastMessageAt DateTime?                              // For sorting channels by recency
  isArchived    Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt
  messages      ChatMessage[]
  participants  ChatParticipant[]

  @@index([createdBy])
  @@index([agentId])
  @@index([jobId])
  @@index([lastMessageAt])
  @@index([type])
}

// Channel participants (who is in each channel)
model ChatParticipant {
  id          String      @id @default(uuid())
  channelId   String
  channel     ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  wallet      String                                   // User wallet address
  displayName String?                                  // Cached display name
  role        String      @default("member")           // owner | admin | member
  lastReadAt  DateTime?                                // For unread count
  isMuted     Boolean     @default(false)
  joinedAt    DateTime    @default(now())

  @@unique([channelId, wallet])
  @@index([wallet])
  @@index([channelId])
}

// Individual chat messages
model ChatMessage {
  id          String      @id @default(uuid())
  channelId   String
  channel     ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderWallet String                                  // "0x..." for users, "agent:<agentId>" for agents
  senderName  String?                                  // Display name at time of sending
  content     String                                   // Message text (markdown supported)
  messageType String      @default("text")             // text | system | file | tx_link | agent_result
  metadata    Json?                                    // Attachments, tx refs, agent outputs
  replyToId   String?                                  // Thread reply reference
  isEdited    Boolean     @default(false)
  isDeleted   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  editedAt    DateTime?

  @@index([channelId, createdAt])
  @@index([senderWallet])
  @@index([replyToId])
}

// 4D audit trail — temporal event logging (Feature 4)
model AuditEvent {
  id              String        @id @default(uuid())
  swarmId         String?
  swarm           SwarmSession? @relation(fields: [swarmId], references: [id])
  agentId         String?                                 // MarketplaceAgent id or wallet
  agentName       String?
  eventType       String                                  // SWARM_CREATED, MILESTONE_APPROVED, A2A_TRANSFER, ESCROW_LOCKED, etc.
  title           String
  description     String?
  metadata        Json?                                   // Arbitrary JSON payload
  txHash          String?
  severity        String        @default("INFO")          // INFO, SUCCESS, WARNING, ERROR

  createdAt       DateTime      @default(now())

  @@index([swarmId])
  @@index([agentId])
  @@index([eventType])
  @@index([createdAt])
}

// ==========================================
// ⏰ TEMPO AA: SCHEDULED TRANSACTIONS
// ==========================================

// Pre-signed transactions with time-window execution (Tempo validAfter/validBefore)
model ScheduledTransaction {
  id            String    @id @default(uuid())
  wallet        String                                     // Sender address
  label         String                                     // "Payroll March 2026" or "Agent budget refill"
  toAddress     String                                     // Target contract
  calldata      String                                     // Hex-encoded calldata
  value         String    @default("0")                    // Value in wei (string for BigInt)
  token         String?                                    // Token symbol if applicable
  validAfter    DateTime                                   // Earliest execution time (Tempo validAfter)
  validBefore   DateTime                                   // Latest execution time (Tempo validBefore)
  status        String    @default("PENDING")              // PENDING | BROADCAST | CONFIRMED | EXPIRED | CANCELLED
  txHash        String?
  gasUsed       String?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  executedAt    DateTime?

  @@index([wallet])
  @@index([status])
  @@index([validAfter])
}

// ==========================================
// 🔑 TEMPO AA: ACCESS KEYS
// ==========================================

// Scoped signing authority for agent embedded wallets (Tempo Access Keys)
model AccessKey {
  id                String    @id @default(uuid())
  agentId           String?                                // MarketplaceAgent id
  agentWallet       String                                 // Agent's embedded wallet address
  daemonWallet      String                                 // Root account (daemon) that granted the key
  spendingLimit     Float                                  // Max AlphaUSD per period
  spentThisPeriod   Float     @default(0)                  // Amount spent in current period
  periodResetAt     DateTime                               // When spending counter resets
  allowedContracts  String    @default("*")                // CSV of allowed contract addresses, or "*" for all
  validUntil        DateTime                               // Access key expiry
  isActive          Boolean   @default(true)
  revokedAt         DateTime?
  revokeReason      String?
  txCount           Int       @default(0)                  // Total transactions executed with this key
  createdAt         DateTime  @default(now())
  lastUsedAt        DateTime?

  @@unique([agentWallet])
  @@index([agentId])
  @@index([isActive])
  @@index([validUntil])
}

// ==========================================
// 💰 x402 MICROPAYMENTS
// ==========================================

// x402 payment records — HTTP-native micropayments for AI agents
model x402Payment {
  id            String    @id @default(uuid())
  nonce         String    @unique                         // Unique per payment (replay protection)
  payer         String                                    // Agent wallet that paid
  facilitator   String                                    // PayPol treasury
  token         String                                    // Token address
  amount        Float                                     // AlphaUSD amount
  resource      String                                    // What was paid for (e.g., "mcp:send_payment")
  signature     String                                    // EIP-191 payment signature
  timestamp     DateTime                                  // Payment timestamp
  status        String    @default("VERIFIED")            // VERIFIED | SETTLED | FAILED
  txHash        String?                                   // On-chain settlement tx (if batch-settled)
  settledAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([payer])
  @@index([status])
  @@index([resource])
  @@index([createdAt])
}

// ==========================================
// 🕵️ STEALTH ADDRESSES (ERC-5564)
// ==========================================

// Stealth meta-address registry — recipients publish these for senders
model StealthMetaAddress {
  id              String    @id @default(uuid())
  wallet          String    @unique                       // Owner wallet
  spendingPubKey  String                                  // Public spending key
  viewingPubKey   String                                  // Public viewing key
  metaAddress     String                                  // st:tempo:0xSpend:0xView
  createdAt       DateTime  @default(now())
  payments        StealthPayment[]

  @@index([wallet])
}

// Stealth payment announcements — senders publish, recipients scan
model StealthPayment {
  id              String    @id @default(uuid())
  senderWallet    String                                  // Sender (or "anonymous")
  recipientMetaId String                                  // Ref to StealthMetaAddress
  recipientMeta   StealthMetaAddress @relation(fields: [recipientMetaId], references: [id])
  stealthAddress  String                                  // One-time stealth address
  ephemeralPubKey String                                  // Ephemeral key for scanning
  viewTag         String                                  // First byte of shared secret (scan filter)
  amount          Float
  token           String    @default("AlphaUSD")
  memo            String?
  txHash          String?                                 // On-chain transfer tx
  status          String    @default("PENDING")           // PENDING | SENT | CLAIMED | EXPIRED
  createdAt       DateTime  @default(now())
  claimedAt       DateTime?

  @@index([stealthAddress])
  @@index([viewTag])
  @@index([senderWallet])
  @@index([status])
  @@index([createdAt])
}

// ==========================================
// 🧠 VERIFIABLE AI (Model Registry + Decision Proofs)
// ==========================================

// Registered AI models — hash of model weights/code for verification
model ModelRegistry {
  id              String    @id @default(uuid())
  agentId         String                                  // MarketplaceAgent id
  modelName       String                                  // "routing-optimizer-v3"
  modelVersion    String                                  // "3.1.0"
  modelHash       String                                  // keccak256 of model code/weights
  frameworkHash   String?                                 // keccak256 of framework + deps
  inputSchema     String?   @db.Text                      // JSON Schema for inputs
  outputSchema    String?   @db.Text                      // JSON Schema for outputs
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  deprecatedAt    DateTime?

  @@index([agentId])
  @@index([modelHash])
  @@index([isActive])
}

// Decision proofs — cryptographic commitment to AI decisions
model DecisionProof {
  id              String    @id @default(uuid())
  agentId         String                                  // MarketplaceAgent id
  jobId           String?                                 // AgentJob id (optional)
  inputHash       String                                  // keccak256 of input
  outputHash      String?                                 // keccak256 of output (set after verify)
  planHash        String                                  // Pre-execution commitment hash
  resultHash      String?                                 // Post-execution result hash
  modelHash       String?                                 // Model version hash (links to ModelRegistry)
  commitmentId    String?                                 // On-chain AIProofRegistry commitment
  commitTxHash    String?                                 // On-chain commit tx
  verifyTxHash    String?                                 // On-chain verify tx
  verified        Boolean   @default(false)
  matched         Boolean   @default(false)               // Did planHash match resultHash?
  slashed         Boolean   @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([agentId])
  @@index([jobId])
  @@index([verified])
  @@index([matched])
  @@index([commitmentId])
  @@index([createdAt])
}

// ==========================================
// 🏦 PAYFI CREDIT LAYER
// ==========================================

// Credit lines — agents borrow AlphaUSD based on payment history
model CreditLine {
  id              String    @id @default(uuid())
  borrowerWallet  String                                  // Agent wallet
  amount          Float                                   // Principal borrowed
  interestRate    Float                                   // Annual interest rate (%)
  interestAmount  Float                                   // Calculated interest
  totalDue        Float                                   // Principal + interest
  repaidAmount    Float     @default(0)                   // Amount repaid so far
  termDays        Int                                     // Loan term in days
  dueDate         DateTime                                // When the credit is due
  purpose         String?                                 // "Job #xxx working capital"
  creditScore     Int                                     // Score at time of approval
  tier            String                                  // Credit tier name
  status          String    @default("ACTIVE")            // ACTIVE | REPAID | DEFAULTED | CANCELLED
  txHash          String?                                 // Disbursement tx
  repaidAt        DateTime?
  defaultedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  transactions    CreditTransaction[]

  @@index([borrowerWallet])
  @@index([status])
  @@index([dueDate])
  @@index([borrowerWallet, status])
}

// Credit transactions — disbursements, repayments, interest accruals
model CreditTransaction {
  id              String    @id @default(uuid())
  creditLineId    String
  creditLine      CreditLine @relation(fields: [creditLineId], references: [id])
  type            String                                  // DISBURSEMENT | REPAYMENT | INTEREST | AUTO_REPAY
  amount          Float
  description     String?
  txHash          String?
  createdAt       DateTime  @default(now())

  @@index([creditLineId])
  @@index([type])
  @@index([createdAt])
}