// schema.prisma — PayPol Daemon (shares PostgreSQL database with Dashboard)
// Must stay in sync with apps/dashboard/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models the daemon reads/writes

model Workspace {
  id              String   @id @default(uuid())
  name            String   @unique
  adminWallet     String   @unique
  type            String?
  createdAt       DateTime @default(now())
  payloads        TimeVaultPayload[]
}

model TimeVaultPayload {
  id              String   @id @default(uuid())
  workspaceId     String
  name            String?
  token           String   @default("AlphaUSD")
  note            String?
  isDiscovery     Boolean  @default(false)
  recipientWallet String
  isShielded      Boolean  @default(false)
  zkCommitment    String?
  zkProof         String?
  amount          Float?
  status          String   @default("Draft")
  createdAt       DateTime @default(now())
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
}

model AgentJob {
  id              String    @id @default(uuid())
  agentId         String
  clientWallet    String
  prompt          String
  taskDescription String?
  budget          Float
  negotiatedPrice Float?
  platformFee     Float?
  token           String    @default("AlphaUSD")
  status          String    @default("CREATED")
  result          String?
  escrowTxHash    String?
  settleTxHash    String?
  onChainJobId    Int?
  disputeReason   String?
  deadline        DateTime?
  executionTime   Int?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  parentJobId     String?
  parentAgentId   String?
  a2aChainId      String?
  depth           Int       @default(0)
  planHash        String?
  resultHash      String?
  commitmentId    String?
  commitTxHash    String?
  verifyTxHash    String?
  proofMatched    Boolean?
}
