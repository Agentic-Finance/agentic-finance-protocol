// schema.prisma — PayPol Daemon (shares PostgreSQL database with Dashboard)
// Must stay in sync with apps/dashboard/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models the daemon reads/writes

model Workspace {
  id              String   @id @default(uuid())
  name            String   @unique
  adminWallet     String   @unique
  type            String?
  createdAt       DateTime @default(now())
  payloads        TimeVaultPayload[]
}

model TimeVaultPayload {
  id              String   @id @default(uuid())
  workspaceId     String
  name            String?
  token           String   @default("AlphaUSD")
  note            String?
  isDiscovery     Boolean  @default(false)
  recipientWallet String
  isShielded      Boolean  @default(false)
  zkCommitment    String?
  zkProof         String?
  amount          Float?
  status          String   @default("Draft")
  createdAt       DateTime @default(now())
  workspace       Workspace @relation(fields: [workspaceId], references: [id])

  @@index([status])
  @@index([status, isShielded])
  @@index([workspaceId])
  @@index([recipientWallet])
}

model AgentJob {
  id              String    @id @default(uuid())
  agentId         String
  clientWallet    String
  prompt          String
  taskDescription String?
  budget          Float
  negotiatedPrice Float?
  platformFee     Float?
  token           String    @default("AlphaUSD")
  status          String    @default("CREATED")
  result          String?
  escrowTxHash    String?
  settleTxHash    String?
  onChainJobId    Int?
  disputeReason   String?
  deadline        DateTime?
  executionTime   Int?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  parentJobId     String?
  parentAgentId   String?
  a2aChainId      String?
  depth           Int       @default(0)
  planHash        String?
  resultHash      String?
  commitmentId    String?
  commitTxHash    String?
  verifyTxHash    String?
  proofMatched    Boolean?

  @@index([status])
  @@index([onChainJobId])
  @@index([deadline])
  @@index([clientWallet])
}

// ⚡ Conditional Payroll Rules — daemon evaluates these every 60s
model ConditionalRule {
  id              String    @id @default(uuid())
  name            String
  recipients      String                          // JSON: [{ name, wallet, amount, token, note }]
  conditions      String                          // JSON: [{ type, param, operator, value }]
  conditionLogic  String    @default("AND")       // AND / OR
  status          String    @default("Watching")  // Watching, Paused, Triggered, Expired
  triggerCount    Int       @default(0)
  maxTriggers     Int       @default(1)           // -1 = infinite
  cooldownMinutes Int       @default(0)           // 0=one-time, 10080=weekly, 43200=monthly
  note            String?
  createdAt       DateTime  @default(now())
  triggeredAt     DateTime?
}
